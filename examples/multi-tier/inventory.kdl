vars {
    deploy-user "deploy"
}

group "web" {
    host "web-1" "192.168.1.10" user="deploy"
    host "web-2" "192.168.1.11" user="deploy"
}

group "app" {
    host "app-1" "192.168.1.20" user="deploy"
    host "app-2" "192.168.1.21" user="deploy"
}

group "db" {
    host "db-1" "192.168.1.30" user="deploy"
}
