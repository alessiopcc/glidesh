plan "web-server" {
    target "web"
    mode "sync"

    vars {
        server-name "example.com"
        doc-root "/var/www/html"
    }

    step "Install nginx" {
        package "nginx" state="present"
    }

    step "Deploy nginx config" {
        file "/etc/nginx/sites-available/default" {
            src "files/nginx.conf"
            template #true
            owner "root"
            group "root"
            mode "0644"
        }
    }

    step "Start nginx" {
        systemd "nginx" {
            state "started"
            enabled #true
        }
    }

    step "Health check" {
        shell "curl -sf http://localhost/" {
            retries 5
            delay 2
        }
    }
}
