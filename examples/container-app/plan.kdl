plan "container-app" {
    target "app"
    mode "sync"

    vars {
        app-image "nginx:alpine"
        app-port 8080
    }

    step "Deploy application" {
        container "webapp" {
            image "${app-image}"
            state "running"
            restart "always"
            ports {
                - "${app-port}:80"
            }
            environment {
                APP_ENV "production"
                LOG_LEVEL "info"
            }
            volumes {
                - "/data/webapp:/usr/share/nginx/html"
            }
        }
    }

    step "Health check" {
        shell "curl -sf http://localhost:${app-port}" {
            retries 10
            delay 3
        }
    }
}
